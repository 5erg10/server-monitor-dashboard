# Server
NODE_ENV=development
PORT=3500
HOST=0.0.0.0

# JWT
JWT_SECRET=change_this_to_a_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# Google OAuth2
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=

# Authorized users (comma-separated Gmail addresses)
ALLOWED_EMAILS=you@gmail.com,another@gmail.com

# Session
SESSION_SECRET=change_this_to_another_random_secret

# Metrics collector interval (milliseconds)
COLLECTOR_INTERVAL=3000

# SQLite DB path
# Docker:  DB_PATH=/app/data/dashboard.db
# Sin Docker: dejar vacío (usa <raíz-proyecto>/data/dashboard.db) o poner una ruta absoluta con permisos de escritura
# DB_PATH=/app/data/dashboard.db

# Client URL (for CORS in dev)
CLIENT_URL=http://localhost:5173
